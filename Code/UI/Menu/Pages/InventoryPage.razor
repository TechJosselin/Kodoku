@using System;
@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using Kodoku.Items;
@using Kodoku.Player;
@using Kodoku.Player.Inventory;
@using Kodoku.World.Containers;
@namespace Kodoku.UI
@inherits Panel

<root>
	<div class="columns">
		<div class="column inventory-column">
			@if ( Inventory is not null )
			{
				<div class="column-title">Inventory — @Inventory.LocalItemCount item(s)</div>

				<div class="grid-viewport">
					<InventoryGrid @ref="PlayerGridPanel" Width="@Inventory.Width" Height="@Inventory.Height" Items="@BuildPlayerGridItems()" OnItemClicked="@SelectPlayerItem" Ghost="@GetPlayerGhost()" />
				</div>

				<div class="actions-panel">
					@{ var selectedPlayerEntry = FindPlayerEntry( _selectedPlayerItemId ); }
					@if ( selectedPlayerEntry is { } playerEntry )
					{
						var definition = ResolveDefinition( playerEntry.ItemId );
						var instanceId = playerEntry.InstanceId;
						bool storePending = IsItemOperationPending( instanceId );

						<div class="selected-info">@( definition?.DisplayName ?? playerEntry.ItemId ) <span class="qty">x@( playerEntry.Quantity )</span></div>
						<div class="actions">
							<button class="action-button" onclick=@( () => RequestDrop( instanceId ) )>Drop</button>
							@if ( definition is not null && definition.EquipmentSlot != EquipmentSlotType.None )
							{
								<button class="action-button" onclick=@( () => RequestEquip( instanceId, definition.EquipmentSlot ) )>Equip</button>
							}
							@if ( definition is not null && float.IsFinite( definition.ThirstRestoreAmount ) && definition.ThirstRestoreAmount > 0f )
							{
								<button class="action-button" onclick=@( () => RequestUse( instanceId ) )>Use</button>
							}
							@if ( _container.IsValid() && _container.IsLocalSessionOpen )
							{
								<button class="action-button @( storePending ? "pending" : "" )" onclick=@( () => OnPlayerItemClicked( instanceId ) )>Store</button>
							}
						</div>
					}
					else
					{
						<div class="selected-info empty">No item selected</div>
					}
				</div>
			}
			else
			{
				<div class="page-placeholder">
					<div class="page-title">Inventory</div>
					<div class="page-description">Inventory not available yet.</div>
				</div>
			}
		</div>

		<div class="column equipment-column">
			@if ( Inventory is not null )
			{
				<div class="column-title">Equipment</div>
				<div class="entries">
					@foreach ( var slot in EquipmentSlots )
					{
						var equipped = Inventory.LocalEquipment.FirstOrDefault( e => e.Slot == slot );
						bool hasItem = !string.IsNullOrEmpty( equipped.ItemId );
						var definition = hasItem ? ResolveDefinition( equipped.ItemId ) : null;

						<div class="entry">
							<div class="icon">
								@if ( definition is not null && definition.Icon is not null )
								{
									<Image Texture="@definition.Icon"></Image>
								}
								else
								{
									<div class="icon-fallback"></div>
								}
							</div>
							<div class="info">
								<div class="name">
									@slot :
									@if ( hasItem )
									{
										@( definition?.DisplayName ?? equipped.ItemId ) <span class="qty">x@( equipped.Quantity )</span>
									}
									else
									{
										<span class="empty">(empty)</span>
									}
								</div>
							</div>
							@if ( hasItem )
							{
								<button class="action-button" onclick=@( () => RequestUnequip( slot ) )>Unequip</button>
							}
						</div>
					}
				</div>
			}
			else
			{
				<div class="page-placeholder">
					<div class="page-title">Equipment</div>
					<div class="page-description">Equipment not available yet.</div>
				</div>
			}
		</div>

		<div class="column container-column">
			@if ( _container.IsValid() && _container.IsLocalSessionOpen )
			{
				<div class="column-title">
					@_container.GameObject.Name — @_container.LocalEntries.Count item(s)
					<button class="close-button" onclick=@RequestCloseContainer>Close</button>
				</div>

				<div class="grid-viewport">
					<InventoryGrid @ref="ContainerGridPanel" Width="@_container.LocalWidth" Height="@_container.LocalHeight" Items="@BuildContainerGridItems()" OnItemClicked="@SelectContainerItem" Ghost="@GetContainerGhost()" />
				</div>

				<div class="actions-panel">
					@{ var selectedContainerEntry = FindContainerEntry( _selectedContainerItemId ); }
					@if ( selectedContainerEntry is { } containerEntry )
					{
						var definition = ResolveDefinition( containerEntry.ItemId );
						var instanceId = containerEntry.InstanceId;
						bool takePending = IsItemOperationPending( instanceId );

						<div class="selected-info">@( definition?.DisplayName ?? containerEntry.ItemId ) <span class="qty">x@( containerEntry.Quantity )</span></div>
						<div class="actions">
							<button class="action-button @( takePending ? "pending" : "" )" onclick=@( () => OnContainerItemClicked( instanceId ) )>Take</button>
						</div>
					}
					else
					{
						<div class="selected-info empty">No item selected</div>
					}
				</div>
			}
			else
			{
				<div class="page-placeholder">
					<div class="page-title">Container</div>
					<div class="page-description">No container open.</div>
				</div>
			}
		</div>
	</div>
</root>

@code
{
	// Lu à chaque frame (voir Tick ci-dessous), jamais mis en cache durablement — même choix que
	// GameHud : fonctionne que le pawn local existe déjà, n'existe pas encore, ou
	// soit remplacé (déconnexion/reconnexion). N'affiche jamais l'inventaire d'un proxy :
	// KodokuPlayerComponent.Local ne désigne jamais un pawn distant.
	PlayerInventoryComponent Inventory => KodokuPlayerComponent.Local?.PlayerInventory;

	static readonly EquipmentSlotType[] EquipmentSlots = { EquipmentSlotType.Head, EquipmentSlotType.Body };

	static readonly IReadOnlyList<InventoryGridItem> EmptyGridItems = Array.Empty<InventoryGridItem>();

	/// <summary>
	/// Conteneur actuellement affiché dans la 3ème colonne — mis à jour uniquement depuis Tick() par
	/// comparaison à <see cref="WorldContainerComponent.LocalOpenContainer"/>, jamais lu directement
	/// ailleurs dans cette classe. Pas d'abonnement aux événements
	/// <c>LocalContainerOpened</c>/<c>LocalContainerClosed</c> ici : cette page est un Panel imbriqué
	/// recréé à chaque ouverture/fermeture de GameMenu, à durée de vie plus courte qu'un PanelComponent
	/// stable — le polling par Tick évite tout risque de fuite d'abonnement ou de double-abonnement lié
	/// à ce cycle de vie plus court.
	/// </summary>
	WorldContainerComponent _container;

	/// <summary>Nature de l'opération réseau représentée par un <see cref="PendingOperation"/>.</summary>
	enum PendingOperationKind
	{
		Move,
		Store,
		Take,
	}

	/// <summary>
	/// État minimal d'une opération réseau en attente, identifiée par son <see cref="RequestId"/> (jamais
	/// par le seul <c>InstanceId</c>, voir mission « corrélation par RequestId ») — seulement de quoi
	/// répondre à trois questions : « à quel <c>InstanceId</c> cette opération s'applique-t-elle », « le
	/// résultat authoritative est-il arrivé (et avec quel succès) », et pour Store/Take uniquement,
	/// « la source a-t-elle confirmé la disparition de l'item ». Un Move ne quitte jamais son conteneur
	/// d'origine — <see cref="SourceGoneConfirmed"/> n'a donc de sens que pour
	/// <see cref="PendingOperationKind.Store"/>/<see cref="PendingOperationKind.Take"/> (voir
	/// <see cref="ReconcileSourceDisappearance"/>).
	/// </summary>
	sealed class PendingOperation
	{
		public string RequestId;
		public string InstanceId;
		public PendingOperationKind Kind;
		public bool ResultReceived;
		public bool ResultSuccess;
		public bool SourceGoneConfirmed;
	}

	/// <summary>
	/// État complet des opérations réseau spatiales en attente (Move joueur/conteneur, Store/Take ciblés
	/// ou first-fit), indexé par <see cref="PendingOperation.RequestId"/> — jamais par <c>InstanceId"</c>
	/// seul : une <c>InventoryPage</c> détruite puis recréée (changement d'onglet, fermeture du menu)
	/// perd son état pending, mais un résultat retardé pour une opération de l'ancienne page ne doit
	/// jamais pouvoir toucher une nouvelle opération démarrée depuis sur le même <c>InstanceId</c> —
	/// c'est exactement ce que corrèle <see cref="_pendingRequestIdByInstanceId"/> (verrou par
	/// <c>InstanceId</c>, séparé de la table par <c>RequestId</c>). Voir <see cref="IsItemOperationPending"/>
	/// (garde unique) et <see cref="TryRegisterPending"/> (seul point d'ajout aux deux dictionnaires,
	/// atomique). Une opération n'est retirée des deux dictionnaires qu'après avoir observé les deux
	/// confirmations nécessaires en cas de succès Store/Take (résultat authoritative **et** disparition
	/// confirmée de la source) — voir <see cref="MarkResultReceived"/>/<see cref="ReconcileSourceDisappearance"/>
	/// — jamais sur la seule disparition du snapshot, qui pourrait précéder la réception du résultat
	/// correspondant.
	/// </summary>
	readonly Dictionary<string, PendingOperation> _pendingByRequestId = new();

	/// <summary>
	/// Verrou unique par <c>InstanceId</c> : quel <see cref="PendingOperation.RequestId"/> est
	/// actuellement actif pour cet item, s'il y en a un — jamais plus d'une opération active à la fois
	/// par item (voir <see cref="TryRegisterPending"/>). Distinct de <see cref="_pendingByRequestId"/> :
	/// cette table ne connaît que l'opération *active*, tandis qu'un résultat retardé pour un
	/// <c>RequestId</c> qui n'est plus la valeur actuelle ici est un résultat ancien/orphelin, jamais
	/// appliqué (voir <see cref="MarkResultReceived"/>).
	/// </summary>
	readonly Dictionary<string, string> _pendingRequestIdByInstanceId = new();

	/// <summary>
	/// Garde unique à utiliser par tout point d'entrée démarrant une opération sur un item (drag, bouton
	/// Store/Take, Drop, Equip, Use, Unequip) — jamais un test dispersé sur plusieurs collections.
	/// </summary>
	bool IsItemOperationPending( string instanceId ) => !string.IsNullOrEmpty( instanceId ) && _pendingRequestIdByInstanceId.ContainsKey( instanceId );

	/// <summary>
	/// Seul point d'ajout à <see cref="_pendingByRequestId"/>/<see cref="_pendingRequestIdByInstanceId"/>
	/// — retourne <c>false</c> (et n'ajoute rien) si l'item a déjà une opération active, combinant
	/// l'ignorance d'une seconde tentative et l'enregistrement en une seule opération atomique (même
	/// intention que l'ancien <c>HashSet.Add</c>). Génère elle-même un nouveau <c>RequestId</c>
	/// (<c>Guid.NewGuid().ToString("N")</c>) — jamais fourni par l'appelant, jamais généré côté host :
	/// c'est l'identité de CETTE demande cliente précise, qui survit logiquement à la destruction de
	/// cette <c>InventoryPage</c> même si l'état pending local, lui, ne survit pas (voir doc de
	/// <see cref="_pendingByRequestId"/>).
	/// </summary>
	bool TryRegisterPending( string instanceId, PendingOperationKind kind, out string requestId )
	{
		if ( string.IsNullOrEmpty( instanceId ) || _pendingRequestIdByInstanceId.ContainsKey( instanceId ) )
		{
			requestId = null;
			return false;
		}

		requestId = Guid.NewGuid().ToString( "N" );
		_pendingByRequestId[requestId] = new PendingOperation { RequestId = requestId, InstanceId = instanceId, Kind = kind };
		_pendingRequestIdByInstanceId[instanceId] = requestId;
		return true;
	}

	/// <summary>
	/// Retire une opération terminée des deux dictionnaires — seul point de retrait, appelé uniquement
	/// depuis <see cref="MarkResultReceived"/>/<see cref="ReconcileSourceDisappearance"/> une fois les
	/// conditions de libération remplies. Ne retire <see cref="_pendingRequestIdByInstanceId"/> que si
	/// l'entrée y référence encore exactement ce <paramref name="requestId"/> (mission section 4) — une
	/// opération plus récente sur le même <c>InstanceId</c> a pu entre-temps devenir la valeur active,
	/// auquel cas elle ne doit jamais être touchée par la terminaison d'une opération plus ancienne.
	/// </summary>
	void ReleasePending( string requestId, string instanceId )
	{
		_pendingByRequestId.Remove( requestId );

		if ( _pendingRequestIdByInstanceId.TryGetValue( instanceId, out var activeRequestId ) && activeRequestId == requestId )
			_pendingRequestIdByInstanceId.Remove( instanceId );
	}

	/// <summary>
	/// Réconcilie la réception d'un résultat authoritative (Move, Store ou Take, first-fit ou ciblé) —
	/// point d'entrée unique quel que soit le canal réseau d'origine (voir call sites). Un résultat dont
	/// le <paramref name="requestId"/> ne correspond à aucune entrée de <see cref="_pendingByRequestId"/>,
	/// dont l'<c>InstanceId</c> mémorisé diffère de <paramref name="instanceId"/>, ou dont le
	/// <c>RequestId</c> n'est plus la valeur active dans <see cref="_pendingRequestIdByInstanceId"/> pour
	/// cet <c>InstanceId</c>, est un résultat ancien ou orphelin (page précédente détruite, ou déjà
	/// traité) : il est ignoré sans modifier ni libérer quoi que ce soit — jamais utilisé pour libérer
	/// une opération plus récente qui partagerait le même <c>InstanceId</c> (voir mission M1-T3). En
	/// échec, libère immédiatement l'opération correspondante (voir mission section 3). En succès sur un
	/// Move, libère immédiatement (l'item ne quitte jamais son conteneur). En succès sur un Store/Take,
	/// ne libère que si la disparition de la source a déjà été confirmée par ailleurs (voir
	/// <see cref="ReconcileSourceDisappearance"/>) — sinon le drapeau de succès est mémorisé et la
	/// libération est différée jusqu'à cette confirmation, quel que soit l'ordre d'arrivée entre résultat
	/// et snapshot.
	/// </summary>
	void MarkResultReceived( string requestId, string instanceId, bool success )
	{
		if ( string.IsNullOrEmpty( requestId ) || !_pendingByRequestId.TryGetValue( requestId, out var op ) )
			return;

		if ( op.InstanceId != instanceId )
			return;

		if ( !_pendingRequestIdByInstanceId.TryGetValue( instanceId, out var activeRequestId ) || activeRequestId != requestId )
			return;

		op.ResultReceived = true;
		op.ResultSuccess = success;

		if ( !success || op.Kind == PendingOperationKind.Move || op.SourceGoneConfirmed )
			ReleasePending( requestId, instanceId );
	}

	/// <summary>
	/// Appelée depuis <see cref="Tick"/> : détecte, pour chaque opération Store/Take encore en attente,
	/// si l'item a disparu de sa source attendue (inventaire joueur pour Store, conteneur pour Take) —
	/// jamais utilisée seule comme preuve de succès (voir mission section 3 : l'absence visuelle ne
	/// suffit plus, il faut aussi le résultat authoritative). C'est une observation purement locale, qui
	/// ne porte naturellement aucun <c>RequestId</c> — elle ne peut donc marquer
	/// <see cref="PendingOperation.SourceGoneConfirmed"/> que pour l'opération actuellement *active* pour
	/// cet <c>InstanceId</c> (<see cref="_pendingRequestIdByInstanceId"/>), jamais pour une opération plus
	/// ancienne déjà remplacée. Ne libère l'opération que si le résultat de succès a déjà été reçu pour
	/// CE <c>RequestId</c> précis ; sinon mémorise seulement la confirmation pour un traitement différé
	/// par <see cref="MarkResultReceived"/> lorsque le résultat arrivera — une disparition observée ne
	/// vaut jamais, à elle seule, confirmation du succès d'une opération dont le résultat n'est pas
	/// encore arrivé. Les Move ne sont jamais concernés (l'item reste dans le même conteneur).
	/// </summary>
	void ReconcileSourceDisappearance()
	{
		if ( _pendingRequestIdByInstanceId.Count == 0 )
			return;

		var inventory = Inventory;
		bool containerAvailable = _container.IsValid() && _container.IsLocalSessionOpen;

		foreach ( var instanceId in _pendingRequestIdByInstanceId.Keys.ToList() )
		{
			var requestId = _pendingRequestIdByInstanceId[instanceId];
			if ( !_pendingByRequestId.TryGetValue( requestId, out var op ) )
				continue;

			if ( op.SourceGoneConfirmed )
				continue;

			bool gone = op.Kind switch
			{
				PendingOperationKind.Store => inventory is not null && !inventory.LocalEntries.Any( e => e.InstanceId == instanceId ),
				PendingOperationKind.Take => containerAvailable && !_container.LocalEntries.Any( e => e.InstanceId == instanceId ),
				_ => false,
			};

			if ( !gone )
				continue;

			op.SourceGoneConfirmed = true;

			if ( op.ResultReceived && op.ResultSuccess )
				ReleasePending( requestId, instanceId );
		}
	}

	/// <summary>Panel de la grille joueur — capturé via <c>@ref</c> pour la résolution géométrique du drag (voir <see cref="TryBeginPressCandidate"/>/<see cref="ResolveDragTarget"/>).</summary>
	InventoryGrid PlayerGridPanel { get; set; }

	/// <summary>Panel de la grille du conteneur ouvert — mêmes garanties que <see cref="PlayerGridPanel"/>.</summary>
	InventoryGrid ContainerGridPanel { get; set; }

	/// <summary>
	/// État transitoire d'un drag local en cours — jamais un manager global, jamais persisté au-delà de
	/// la durée de vie de cette instance d'<c>InventoryPage</c> (détruite/recréée à chaque changement
	/// d'onglet ou fermeture du menu, voir GameMenu.razor). L'identité canonique reste
	/// <see cref="InstanceId"/>, jamais une référence fragile vers une entrée de liste Razor.
	/// </summary>
	sealed class DragState
	{
		public bool FromContainer;
		public string InstanceId;
		public string ItemId;
		public ItemDefinition Definition;
		public int BaseWidth;
		public int BaseHeight;
		public bool IsRotated;

		/// <summary>
		/// Position/rotation source observées au tout début du drag (jamais mutées ensuite, y compris
		/// si l'utilisateur tourne l'item pendant le drag — voir <see cref="IsRotated"/> pour la
		/// rotation courante) — transmises telles quelles au host comme précondition de fraîcheur (voir
		/// mission section 2 : <c>ExpectedSourceX/Y/Rotated</c>). Le host les revalide contre son propre
		/// état canonique avant toute mutation ; ces champs ne sont jamais eux-mêmes une preuve
		/// d'autorisation, seulement l'état que ce client croyait vrai au moment du drag.
		/// </summary>
		public int OriginX;
		public int OriginY;
		public bool OriginRotated;

		public int GrabDX;
		public int GrabDY;
		public Vector2 PressScreenPosition;
		public bool ThresholdExceeded;
		public bool HasTarget;
		public bool TargetIsContainer;
		public int TargetX;
		public int TargetY;
		public bool TargetValid;
	}

	/// <summary>Seuil de déplacement (pixels écran) avant qu'un appui ne soit promu en drag réel — voir <see cref="UpdateDragState"/>. Nommé explicitement (mission section 7).</summary>
	const float DragThresholdPixels = 6f;

	DragState _drag;

	/// <summary>Dernier <see cref="PlayerInventoryComponent"/> observé, pour réinitialiser le suivi de <see cref="PlayerInventoryComponent.LocalMoveResultSequence"/> si le pawn local change (reconnexion).</summary>
	PlayerInventoryComponent _lastSeenInventoryForMove;

	int _lastSeenPlayerMoveResultSequence;

	int _lastSeenContainerMoveResultSequence;

	/// <summary>
	/// Sélection locale dans la grille joueur — un <c>InstanceId</c>, jamais un index de liste. Pure
	/// présentation : ne déclenche aucun RPC, n'est jamais un état synchronisé. Vidée automatiquement
	/// si l'entrée correspondante disparaît du snapshot (voir <see cref="ValidatePlayerSelection"/>).
	/// </summary>
	string _selectedPlayerItemId;

	/// <summary>
	/// Sélection locale dans la grille du conteneur ouvert — mêmes garanties que
	/// <see cref="_selectedPlayerItemId"/>. Vidée en plus dès que le conteneur affiché change ou se
	/// ferme (voir <see cref="UpdateContainerState"/>).
	/// </summary>
	string _selectedContainerItemId;

	/// <summary>Dernière <see cref="WorldContainerComponent.LocalTransferResultSequence"/> déjà traitée pour <see cref="_container"/>.</summary>
	int _lastSeenTransferResultSequence;

	// Ce composant est un Panel imbriqué dans GameMenu (PanelComponent), pas un PanelComponent
	// lui-même — il n'a donc pas de BuildHash()/OnUpdate() propres. Tick() est l'équivalent pour un
	// Panel simple (« Called every frame », doc XML locale) : on calcule un hash de tout ce qui doit
	// déclencher un nouveau rendu et on appelle StateHasChanged() uniquement s'il a changé, même
	// principe que BuildHash ailleurs dans ce projet, juste porté manuellement ici.
	int _lastObservedHash;

	public override void Tick()
	{
		UpdateContainerState();
		UpdatePlayerMoveResultState();
		ReconcileSourceDisappearance();
		UpdateDragState();

		int hash = ComputeHash();
		if ( hash == _lastObservedHash )
			return;

		_lastObservedHash = hash;
		StateHasChanged();
	}

	void UpdateContainerState()
	{
		var current = WorldContainerComponent.LocalOpenContainer;
		if ( _container != current )
		{
			_container = current;
			_lastSeenTransferResultSequence = _container.IsValid() ? _container.LocalTransferResultSequence : 0;
			_lastSeenContainerMoveResultSequence = _container.IsValid() ? _container.LocalMoveResultSequence : 0;
			ClearPendingState();
			_selectedContainerItemId = null;
		}

		if ( !_container.IsValid() )
		{
			ClearPendingState();
			_selectedContainerItemId = null;
			ValidatePlayerSelection();
			return;
		}

		// Résultat de transfert le plus récent (Take/Store, first-fit ou ciblé) — voir
		// MarkResultReceived pour le cycle de vie exact (succès Store/Take différé jusqu'à confirmation
		// de la disparition de la source, voir ReconcileSourceDisappearance).
		if ( _container.LocalTransferResultSequence != _lastSeenTransferResultSequence )
		{
			_lastSeenTransferResultSequence = _container.LocalTransferResultSequence;
			var result = _container.LastTransferResult;
			MarkResultReceived( result.RequestId, result.InstanceId, result.Success );
		}

		if ( _container.LocalMoveResultSequence != _lastSeenContainerMoveResultSequence )
		{
			_lastSeenContainerMoveResultSequence = _container.LocalMoveResultSequence;
			var moveResult = _container.LastMoveResult;
			MarkResultReceived( moveResult.RequestId, moveResult.InstanceId, moveResult.Success );
		}

		if ( _selectedContainerItemId is not null && !_container.LocalEntries.Any( e => e.InstanceId == _selectedContainerItemId ) )
			_selectedContainerItemId = null;

		ValidatePlayerSelection();
	}

	void ValidatePlayerSelection()
	{
		if ( _selectedPlayerItemId is null )
			return;

		var inventory = Inventory;
		if ( inventory is null || !inventory.LocalEntries.Any( e => e.InstanceId == _selectedPlayerItemId ) )
			_selectedPlayerItemId = null;
	}

	void ClearPendingState()
	{
		_pendingByRequestId.Clear();
		_pendingRequestIdByInstanceId.Clear();
	}

	/// <summary>
	/// Réconcilie le résultat du dernier déplacement interne joueur (voir
	/// <see cref="PlayerInventoryComponent.LocalMoveResultSequence"/>) — distinct de
	/// <see cref="UpdateContainerState"/> : le pawn local (et donc son <see cref="PlayerInventoryComponent"/>)
	/// n'a pas la même durée de vie que le conteneur monde ouvert, suivi indépendamment ici.
	/// </summary>
	void UpdatePlayerMoveResultState()
	{
		var inventory = Inventory;

		if ( inventory != _lastSeenInventoryForMove )
		{
			_lastSeenInventoryForMove = inventory;
			_lastSeenPlayerMoveResultSequence = inventory?.LocalMoveResultSequence ?? 0;
			return;
		}

		if ( inventory is null )
			return;

		if ( inventory.LocalMoveResultSequence != _lastSeenPlayerMoveResultSequence )
		{
			_lastSeenPlayerMoveResultSequence = inventory.LocalMoveResultSequence;
			var moveResult = inventory.LastMoveResult;
			MarkResultReceived( moveResult.RequestId, moveResult.InstanceId, moveResult.Success );
		}
	}

	int ComputeHash()
	{
		var hash = new HashCode();

		var inventory = Inventory;
		hash.Add( inventory );

		if ( inventory is not null )
		{
			hash.Add( inventory.LocalRevision );
			hash.Add( inventory.Width );
			hash.Add( inventory.Height );

			foreach ( var entry in inventory.LocalEntries )
			{
				hash.Add( entry.InstanceId );
				hash.Add( entry.ItemId );
				hash.Add( entry.Quantity );
				hash.Add( entry.X );
				hash.Add( entry.Y );
				hash.Add( entry.IsRotated );
			}

			foreach ( var equipped in inventory.LocalEquipment )
			{
				hash.Add( equipped.Slot );
				hash.Add( equipped.InstanceId );
				hash.Add( equipped.ItemId );
				hash.Add( equipped.Quantity );
			}
		}

		bool containerOpen = _container.IsValid() && _container.IsLocalSessionOpen;
		hash.Add( _container );
		hash.Add( containerOpen );

		if ( containerOpen )
		{
			hash.Add( _container.LocalRevision );
			hash.Add( _container.LocalWidth );
			hash.Add( _container.LocalHeight );

			foreach ( var entry in _container.LocalEntries )
			{
				hash.Add( entry.InstanceId );
				hash.Add( entry.ItemId );
				hash.Add( entry.Quantity );
				hash.Add( entry.X );
				hash.Add( entry.Y );
				hash.Add( entry.IsRotated );
			}
		}

		foreach ( var kv in _pendingByRequestId )
		{
			hash.Add( kv.Key );
			hash.Add( kv.Value.InstanceId );
			hash.Add( kv.Value.Kind );
			hash.Add( kv.Value.ResultReceived );
			hash.Add( kv.Value.ResultSuccess );
			hash.Add( kv.Value.SourceGoneConfirmed );
		}

		hash.Add( _selectedPlayerItemId );
		hash.Add( _selectedContainerItemId );

		// L'aperçu fantôme doit se redessiner à chaque frame où sa position/validité change pendant un
		// drag actif — sans ces champs, Tick() ne détecterait aucun changement entre deux positions de
		// pointeur différentes tant qu'aucune autre donnée (snapshot, sélection...) ne varie.
		if ( _drag is not null )
		{
			hash.Add( _drag.InstanceId );
			hash.Add( _drag.ThresholdExceeded );
			hash.Add( _drag.HasTarget );
			hash.Add( _drag.TargetIsContainer );
			hash.Add( _drag.TargetX );
			hash.Add( _drag.TargetY );
			hash.Add( _drag.TargetValid );
			hash.Add( _drag.IsRotated );
		}

		return hash.ToHashCode();
	}

	// Résolution locale d'ItemDefinition depuis l'ItemId brut du snapshot — présentation uniquement
	// (icône, nom affiché, dimensions visuelles, quel bouton afficher), jamais une validation métier :
	// le host revalide tout depuis Container/ItemDefinition canoniques. Le résultat de
	// ResourceLibrary.GetAll<ItemDefinition>() est mis en cache plutôt que reconstruit à chaque entrée
	// et à chaque frame — voir mission section 9.
	static Dictionary<string, ItemDefinition> _definitionCache;
	static int _definitionCacheSourceCount = -1;

	/// <summary>
	/// Reconstruit <see cref="_definitionCache"/> uniquement si le nombre total de ItemDefinition
	/// connues a changé depuis la dernière reconstruction (ajout/suppression d'un .item, hotload
	/// éditeur) — jamais inconditionnellement à chaque appel. Un cache figé une seule fois pour toute
	/// la durée du process aurait servi des références obsolètes après un hotload d'assets en éditeur
	/// (scénario réel pendant les sessions de test manuelles de ce jalon).
	///
	/// Appelée une seule fois par colonne au tout début de <see cref="BuildPlayerGridItems"/> et de
	/// <see cref="BuildContainerGridItems"/> — jamais depuis <see cref="ResolveDefinition"/> elle-même,
	/// qui reste une simple lecture de dictionnaire. Dans le rendu Razor de cette page, la colonne
	/// Inventory (grille + panneau d'actions) et la colonne Equipment sont rendues avant la colonne
	/// Container, dans cet ordre, en un seul passage synchrone : appeler cette méthode au début de
	/// BuildPlayerGridItems() garantit donc le cache déjà prêt pour tous les appels ultérieurs de
	/// ResolveDefinition() dans le même rendu (panneau d'actions joueur, colonne Equipment) sans
	/// dépendre d'un hook de cycle de vie Razor non confirmé ; BuildContainerGridItems() ré-appelle la
	/// même garde (idempotente, coût négligeable si déjà à jour) pour rester correcte même si la
	/// colonne Inventory ne s'est pas rendue (aucun Inventory local, cas rare mais possible).
	///
	/// Coût réel par appel : un <c>ResourceLibrary.GetAll&lt;ItemDefinition&gt;().Count()</c> — la
	/// documentation XML locale de <c>ResourceLibrary.GetAll</c> le décrit comme un accès à des
	/// « cached resources », donc un index déjà maintenu par le moteur (mis à jour de façon
	/// incrémentale via <c>IEventListener.OnRegister/OnUnregister</c>), pas un balayage disque ni une
	/// recompilation à chaque appel. Sans commune mesure avec le <c>FirstOrDefault(predicate)</c> par
	/// entrée qu'il remplace (voir mission section 9). Invalidation volontairement légère (comptage,
	/// pas de service/registre dédié) : elle ne protège pas un ItemId renommé en place sans changement
	/// du nombre total de définitions — risque jugé trop rare pour ce jalon V1 (voir rapport).
	/// </summary>
	static void EnsureDefinitionCache()
	{
		var known = ResourceLibrary.GetAll<ItemDefinition>();
		int count = known.Count();

		if ( _definitionCache is not null && count == _definitionCacheSourceCount )
			return;

		_definitionCache = new Dictionary<string, ItemDefinition>();

		foreach ( var definition in known )
		{
			if ( !string.IsNullOrEmpty( definition.ItemId ) )
				_definitionCache[definition.ItemId] = definition;
		}

		_definitionCacheSourceCount = count;
	}

	// Lecture pure de dictionnaire — n'appelle plus EnsureDefinitionCache() elle-même (voir sa doc) :
	// le cache doit déjà être prêt au moment où cette méthode est appelée.
	static ItemDefinition ResolveDefinition( string itemId )
	{
		if ( string.IsNullOrEmpty( itemId ) || _definitionCache is null )
			return null;

		return _definitionCache.TryGetValue( itemId, out var resolved ) ? resolved : null;
	}

	InventorySnapshotEntry? FindPlayerEntry( string instanceId )
	{
		if ( string.IsNullOrEmpty( instanceId ) || Inventory is null )
			return null;

		foreach ( var entry in Inventory.LocalEntries )
		{
			if ( entry.InstanceId == instanceId )
				return entry;
		}

		return null;
	}

	WorldContainerSnapshotEntry? FindContainerEntry( string instanceId )
	{
		if ( string.IsNullOrEmpty( instanceId ) || !_container.IsValid() )
			return null;

		foreach ( var entry in _container.LocalEntries )
		{
			if ( entry.InstanceId == instanceId )
				return entry;
		}

		return null;
	}

	// Construit les entrées de présentation pour InventoryGrid — jamais mis en cache entre deux appels :
	// n'est invoqué que lors d'une reconstruction Razor réelle (déclenchée par le hash de Tick()), donc
	// déjà au rythme le plus bas possible sans changement réel. La taille visuelle (Width/Height) est
	// déjà celle tournée si IsRotated — voir InventoryGridItem.
	IReadOnlyList<InventoryGridItem> BuildPlayerGridItems()
	{
		var inventory = Inventory;
		if ( inventory is null )
			return EmptyGridItems;

		EnsureDefinitionCache();

		var items = new List<InventoryGridItem>( inventory.LocalEntries.Count );

		foreach ( var entry in inventory.LocalEntries )
		{
			var definition = ResolveDefinition( entry.ItemId );
			int defWidth = definition?.GridWidth ?? 1;
			int defHeight = definition?.GridHeight ?? 1;

			items.Add( new InventoryGridItem(
				entry.InstanceId,
				entry.ItemId,
				definition?.DisplayName ?? entry.ItemId,
				definition?.Icon,
				entry.Quantity,
				entry.X,
				entry.Y,
				entry.IsRotated ? defHeight : defWidth,
				entry.IsRotated ? defWidth : defHeight,
				entry.IsRotated,
				IsItemOperationPending( entry.InstanceId ),
				entry.InstanceId == _selectedPlayerItemId
			) );
		}

		return items;
	}

	IReadOnlyList<InventoryGridItem> BuildContainerGridItems()
	{
		if ( !_container.IsValid() )
			return EmptyGridItems;

		EnsureDefinitionCache();

		var items = new List<InventoryGridItem>( _container.LocalEntries.Count );

		foreach ( var entry in _container.LocalEntries )
		{
			var definition = ResolveDefinition( entry.ItemId );
			int defWidth = definition?.GridWidth ?? 1;
			int defHeight = definition?.GridHeight ?? 1;

			items.Add( new InventoryGridItem(
				entry.InstanceId,
				entry.ItemId,
				definition?.DisplayName ?? entry.ItemId,
				definition?.Icon,
				entry.Quantity,
				entry.X,
				entry.Y,
				entry.IsRotated ? defHeight : defWidth,
				entry.IsRotated ? defWidth : defHeight,
				entry.IsRotated,
				IsItemOperationPending( entry.InstanceId ),
				entry.InstanceId == _selectedContainerItemId
			) );
		}

		return items;
	}

	// Sélection locale uniquement — aucun RPC, aucune mutation de snapshot. Voir mission section 15.
	void SelectPlayerItem( string instanceId ) => _selectedPlayerItemId = instanceId;

	void SelectContainerItem( string instanceId ) => _selectedContainerItemId = instanceId;

	// Ne transmet que l'InstanceId/le slot sélectionné dans le snapshot local — aucune donnée métier
	// (définition, quantité, position) envoyée ; le host revalide tout. Mêmes points d'entrée déjà
	// validés par test réel. Gardés par IsItemOperationPending (voir mission section 3, garde globale) :
	// tant qu'une opération spatiale (Move/Store/Take) est en attente sur cet item, Drop/Equip/Use ne
	// doivent pas pouvoir démarrer une opération concurrente sur le même InstanceId — ces quatre actions
	// ne portent en revanche pas leur propre suivi pending (inchangé, hors périmètre de cette passe).
	void RequestDrop( string instanceId )
	{
		if ( IsItemOperationPending( instanceId ) )
			return;

		KodokuPlayerComponent.Local?.PlayerItemDrop?.RequestDrop( instanceId );
	}

	void RequestEquip( string instanceId, EquipmentSlotType slot )
	{
		if ( IsItemOperationPending( instanceId ) )
			return;

		KodokuPlayerComponent.Local?.PlayerInventory?.RequestEquip( instanceId, slot );
	}

	void RequestUse( string instanceId )
	{
		if ( IsItemOperationPending( instanceId ) )
			return;

		KodokuPlayerComponent.Local?.PlayerItemUse?.RequestUse( instanceId );
	}

	void RequestUnequip( EquipmentSlotType slot )
	{
		var inventory = Inventory;
		var equipped = inventory?.LocalEquipment.FirstOrDefault( e => e.Slot == slot );

		if ( equipped is { InstanceId: { } equippedInstanceId } && IsItemOperationPending( equippedInstanceId ) )
			return;

		inventory?.RequestUnequip( slot );
	}

	// TryRegisterPending retourne false si déjà pending — combine l'ignorance d'un second clic et
	// l'enregistrement en une seule opération atomique (même intention que l'ancien HashSet.Add).
	void OnContainerItemClicked( string instanceId )
	{
		if ( !_container.IsValid() )
			return;

		if ( !TryRegisterPending( instanceId, PendingOperationKind.Take, out var requestId ) )
			return;

		_container.RequestTakeItem( requestId, instanceId );
	}

	void OnPlayerItemClicked( string instanceId )
	{
		if ( !_container.IsValid() )
			return;

		if ( !TryRegisterPending( instanceId, PendingOperationKind.Store, out var requestId ) )
			return;

		_container.RequestStoreItem( requestId, instanceId );
	}

	void RequestCloseContainer() => _container?.CloseLocalSessionImmediately();

	// --- Drag-and-drop V1 ---
	//
	// Toute la détection de pointeur (down/relâchement/déplacement) est centralisée ici, au niveau de
	// cette page, plutôt que dans chaque InventoryGrid : un drag doit pouvoir franchir la frontière
	// entre la grille joueur et celle du conteneur (Store/Take ciblés), et la documentation locale de
	// Panel.OnMouseMove ("Called when the cursor moves while hovering this panel") ne garantit ce
	// callback que pour le panel survolé au moment présent — pas nécessairement celui qui a capturé
	// l'appui initial si le pointeur quitte ses bornes pendant un drag. Mouse.Position (position écran
	// globale, déjà utilisée ainsi par SliderControl/ColorHueControl dans la bibliothèque du moteur pour
	// des drags qui dépassent les bornes du panel d'origine) reste en revanche fiable en toutes
	// circonstances, interrogée ici à chaque frame (Tick(), voir UpdateDragState) plutôt que dans
	// OnMouseMove. Le relâchement est détecté par la perte de HasActive (pseudo-classe :active, déjà
	// utilisée pour le même usage par ColorHueControl) plutôt qu'un OnMouseUp dont le ciblage exact
	// n'est pas garanti dans ce même scénario multi-panel.

	protected override void OnMouseDown( MousePanelEvent e )
	{
		base.OnMouseDown( e );

		if ( e.MouseButton == MouseButtons.Right )
		{
			CancelDrag();
			return;
		}

		if ( e.MouseButton != MouseButtons.Left || _drag is not null )
			return;

		TryBeginPressCandidate();
	}

	/// <summary>
	/// Détecte un appui sur un item de l'une ou l'autre grille (position écran globale, voir
	/// commentaire de section ci-dessus) et enregistre un candidat de drag — jamais encore un drag réel
	/// tant que <see cref="DragThresholdPixels"/> n'est pas dépassé (voir <see cref="UpdateDragState"/>).
	/// Aucune RPC n'est jamais envoyée depuis cette méthode.
	/// </summary>
	void TryBeginPressCandidate()
	{
		var screenPos = Mouse.Position;

		if ( PlayerGridPanel is not null && PlayerGridPanel.TryGetCellAtScreenPosition( screenPos, out var px, out var py ) )
		{
			var entry = FindPlayerEntryAtCell( px, py );
			if ( entry is { } playerEntry )
			{
				BeginPressCandidate( fromContainer: false, playerEntry.InstanceId, playerEntry.ItemId, playerEntry.X, playerEntry.Y, playerEntry.IsRotated, px, py, screenPos );
				return;
			}
		}

		if ( _container.IsValid() && _container.IsLocalSessionOpen && ContainerGridPanel is not null && ContainerGridPanel.TryGetCellAtScreenPosition( screenPos, out var cx, out var cy ) )
		{
			var entry = FindContainerEntryAtCell( cx, cy );
			if ( entry is { } containerEntry )
				BeginPressCandidate( fromContainer: true, containerEntry.InstanceId, containerEntry.ItemId, containerEntry.X, containerEntry.Y, containerEntry.IsRotated, cx, cy, screenPos );
		}
	}

	void BeginPressCandidate( bool fromContainer, string instanceId, string itemId, int originX, int originY, bool isRotated, int pressCellX, int pressCellY, Vector2 screenPos )
	{
		// Un item ayant déjà une opération réseau en attente (bouton, Drop/Equip/Use, ou drag précédent)
		// ne peut pas démarrer un second drag concurrent local (voir mission section 3, garde globale).
		if ( IsItemOperationPending( instanceId ) )
			return;

		EnsureDefinitionCache();
		var definition = ResolveDefinition( itemId );

		_drag = new DragState
		{
			FromContainer = fromContainer,
			InstanceId = instanceId,
			ItemId = itemId,
			Definition = definition,
			BaseWidth = definition?.GridWidth ?? 1,
			BaseHeight = definition?.GridHeight ?? 1,
			IsRotated = isRotated,
			OriginX = originX,
			OriginY = originY,
			OriginRotated = isRotated,
			GrabDX = pressCellX - originX,
			GrabDY = pressCellY - originY,
			PressScreenPosition = screenPos,
			ThresholdExceeded = false,
		};
	}

	InventorySnapshotEntry? FindPlayerEntryAtCell( int x, int y )
	{
		var inventory = Inventory;
		if ( inventory is null )
			return null;

		EnsureDefinitionCache();

		foreach ( var entry in inventory.LocalEntries )
		{
			var definition = ResolveDefinition( entry.ItemId );
			int w = entry.IsRotated ? ( definition?.GridHeight ?? 1 ) : ( definition?.GridWidth ?? 1 );
			int h = entry.IsRotated ? ( definition?.GridWidth ?? 1 ) : ( definition?.GridHeight ?? 1 );

			if ( x >= entry.X && x < entry.X + w && y >= entry.Y && y < entry.Y + h )
				return entry;
		}

		return null;
	}

	WorldContainerSnapshotEntry? FindContainerEntryAtCell( int x, int y )
	{
		if ( !_container.IsValid() )
			return null;

		EnsureDefinitionCache();

		foreach ( var entry in _container.LocalEntries )
		{
			var definition = ResolveDefinition( entry.ItemId );
			int w = entry.IsRotated ? ( definition?.GridHeight ?? 1 ) : ( definition?.GridWidth ?? 1 );
			int h = entry.IsRotated ? ( definition?.GridWidth ?? 1 ) : ( definition?.GridHeight ?? 1 );

			if ( x >= entry.X && x < entry.X + w && y >= entry.Y && y < entry.Y + h )
				return entry;
		}

		return null;
	}

	/// <summary>
	/// Appelée depuis <see cref="Tick"/> : fait progresser un candidat/drag en cours d'une frame à
	/// l'autre — seuil de déclenchement, rotation, résolution de la cellule cible, relâchement.
	/// </summary>
	void UpdateDragState()
	{
		if ( _drag is null )
			return;

		// Annulation si la source a disparu (item pris ailleurs, conteneur fermé/invalidé entre-temps) —
		// voir mission D1-Q. Vérifié à chaque frame, pas seulement au début du drag.
		if ( _drag.FromContainer )
		{
			if ( !_container.IsValid() || !_container.IsLocalSessionOpen || FindContainerEntry( _drag.InstanceId ) is null )
			{
				_drag = null;
				return;
			}
		}
		else if ( FindPlayerEntry( _drag.InstanceId ) is null )
		{
			_drag = null;
			return;
		}

		// Relâchement détecté par la perte de :active (voir commentaire de section) plutôt qu'un
		// OnMouseUp dont le ciblage n'est pas garanti dans ce scénario multi-panel.
		if ( !HasActive )
		{
			if ( _drag.ThresholdExceeded )
				ReleaseDrag();
			else
				_drag = null; // clic simple sous le seuil — la sélection est déjà gérée par onclick, rien d'autre à faire ici

			return;
		}

		var screenPos = Mouse.Position;

		if ( !_drag.ThresholdExceeded )
		{
			if ( ( screenPos - _drag.PressScreenPosition ).Length < DragThresholdPixels )
				return;

			_drag.ThresholdExceeded = true;
		}

		if ( Input.Pressed( "InventoryRotate" ) && ( _drag.Definition?.CanRotate ?? false ) )
			_drag.IsRotated = !_drag.IsRotated;

		ResolveDragTarget( screenPos );
	}

	void ResolveDragTarget( Vector2 screenPos )
	{
		int width = _drag.IsRotated ? _drag.BaseHeight : _drag.BaseWidth;
		int height = _drag.IsRotated ? _drag.BaseWidth : _drag.BaseHeight;

		if ( PlayerGridPanel is not null && PlayerGridPanel.TryGetCellAtScreenPosition( screenPos, out var px, out var py ) )
		{
			_drag.HasTarget = true;
			_drag.TargetIsContainer = false;
			_drag.TargetX = px - _drag.GrabDX;
			_drag.TargetY = py - _drag.GrabDY;
			_drag.TargetValid = IsPlayerPlacementValid( _drag.InstanceId, _drag.TargetX, _drag.TargetY, width, height );
			return;
		}

		if ( _container.IsValid() && _container.IsLocalSessionOpen && ContainerGridPanel is not null && ContainerGridPanel.TryGetCellAtScreenPosition( screenPos, out var cx, out var cy ) )
		{
			_drag.HasTarget = true;
			_drag.TargetIsContainer = true;
			_drag.TargetX = cx - _drag.GrabDX;
			_drag.TargetY = cy - _drag.GrabDY;
			_drag.TargetValid = IsContainerPlacementValid( _drag.InstanceId, _drag.TargetX, _drag.TargetY, width, height );
			return;
		}

		_drag.HasTarget = false;
	}

	/// <summary>
	/// Validation locale indicative uniquement (voir mission section 9) — guide l'utilisateur, ne
	/// remplace jamais la validation host. Fondée sur le dernier snapshot local reçu, qui peut être
	/// périmé au moment où le host traite réellement la requête.
	/// </summary>
	bool IsPlayerPlacementValid( string instanceId, int x, int y, int width, int height )
	{
		var inventory = Inventory;
		if ( inventory is null )
			return false;

		if ( x < 0 || y < 0 || x + width > inventory.Width || y + height > inventory.Height )
			return false;

		foreach ( var entry in inventory.LocalEntries )
		{
			if ( entry.InstanceId == instanceId )
				continue;

			var definition = ResolveDefinition( entry.ItemId );
			int w = entry.IsRotated ? ( definition?.GridHeight ?? 1 ) : ( definition?.GridWidth ?? 1 );
			int h = entry.IsRotated ? ( definition?.GridWidth ?? 1 ) : ( definition?.GridHeight ?? 1 );

			if ( x < entry.X + w && entry.X < x + width && y < entry.Y + h && entry.Y < y + height )
				return false;
		}

		return true;
	}

	bool IsContainerPlacementValid( string instanceId, int x, int y, int width, int height )
	{
		if ( !_container.IsValid() )
			return false;

		if ( x < 0 || y < 0 || x + width > _container.LocalWidth || y + height > _container.LocalHeight )
			return false;

		foreach ( var entry in _container.LocalEntries )
		{
			if ( entry.InstanceId == instanceId )
				continue;

			var definition = ResolveDefinition( entry.ItemId );
			int w = entry.IsRotated ? ( definition?.GridHeight ?? 1 ) : ( definition?.GridWidth ?? 1 );
			int h = entry.IsRotated ? ( definition?.GridWidth ?? 1 ) : ( definition?.GridHeight ?? 1 );

			if ( x < entry.X + w && entry.X < x + width && y < entry.Y + h && entry.Y < y + height )
				return false;
		}

		return true;
	}

	/// <summary>
	/// Termine un drag ayant dépassé le seuil — envoie au plus une requête authoritative, seulement si
	/// relâché sur une cible valide (indicative) ; sinon aucune RPC, l'item reste à sa position
	/// canonique (voir mission section 9 : le client accepte qu'un aperçu vert soit finalement refusé,
	/// mais ici il n'est même pas envoyé si l'aperçu local est déjà rouge/hors cible).
	/// </summary>
	void ReleaseDrag()
	{
		var drag = _drag;
		_drag = null;

		if ( !drag.HasTarget || !drag.TargetValid )
			return;

		if ( !drag.FromContainer && !drag.TargetIsContainer )
		{
			if ( TryRegisterPending( drag.InstanceId, PendingOperationKind.Move, out var requestId ) )
				KodokuPlayerComponent.Local?.PlayerInventory?.RequestMoveItem( requestId, drag.InstanceId, drag.TargetX, drag.TargetY, drag.IsRotated, drag.OriginX, drag.OriginY, drag.OriginRotated );
		}
		else if ( drag.FromContainer && drag.TargetIsContainer )
		{
			if ( _container.IsValid() && TryRegisterPending( drag.InstanceId, PendingOperationKind.Move, out var requestId ) )
				_container.RequestMoveItem( requestId, drag.InstanceId, drag.TargetX, drag.TargetY, drag.IsRotated, drag.OriginX, drag.OriginY, drag.OriginRotated );
		}
		else if ( !drag.FromContainer )
		{
			if ( _container.IsValid() && TryRegisterPending( drag.InstanceId, PendingOperationKind.Store, out var requestId ) )
				_container.RequestStoreItemAt( requestId, drag.InstanceId, drag.TargetX, drag.TargetY, drag.IsRotated, drag.OriginX, drag.OriginY, drag.OriginRotated );
		}
		else
		{
			if ( _container.IsValid() && TryRegisterPending( drag.InstanceId, PendingOperationKind.Take, out var requestId ) )
				_container.RequestTakeItemAt( requestId, drag.InstanceId, drag.TargetX, drag.TargetY, drag.IsRotated, drag.OriginX, drag.OriginY, drag.OriginRotated );
		}
	}

	/// <summary>Annulation locale pure (Escape/clic droit/etc.) — jamais de RPC envoyée avant relâchement, donc rien à défaire côté réseau.</summary>
	void CancelDrag() => _drag = null;

	InventoryGridGhost? GetPlayerGhost()
	{
		if ( _drag is null || !_drag.ThresholdExceeded || !_drag.HasTarget || _drag.TargetIsContainer )
			return null;

		return BuildGhost();
	}

	InventoryGridGhost? GetContainerGhost()
	{
		if ( _drag is null || !_drag.ThresholdExceeded || !_drag.HasTarget || !_drag.TargetIsContainer )
			return null;

		return BuildGhost();
	}

	InventoryGridGhost BuildGhost()
	{
		int width = _drag.IsRotated ? _drag.BaseHeight : _drag.BaseWidth;
		int height = _drag.IsRotated ? _drag.BaseWidth : _drag.BaseHeight;
		return new InventoryGridGhost( _drag.TargetX, _drag.TargetY, width, height, _drag.TargetValid );
	}
}
